# Copy this file to `.env` and fill in the real values.
# NOTE: `.env` is ignored by git (see .gitignore).

# Google Cloud API key with access to:
# - Vision API
# - Programmable Search (Custom Search API)
GOOGLE_API_KEY=YOUR_GOOGLE_CLOUD_API_KEY

# Google Programmable Search Engine (CSE) ID (a.k.a. cx)
SEARCH_ENGINE_ID=YOUR_SEARCH_ENGINE_ID

# Gemini API key (Google AI Studio / Generative Language API)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Supabase project settings
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
